# ExplainX Environment Example
# Copy to `.env` at the repository root (and optionally `apps/web/.env.local`).
# Never commit real secrets.

# --- Application ---
EXPLAINX_ENV=development
EXPLAINX_APP_NAME=ExplainX
EXPLAINX_API_VERSION=v1
EXPLAINX_DEBUG=true

# --- Server ---
EXPLAINX_HOST=127.0.0.1
EXPLAINX_PORT=8000
EXPLAINX_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# --- Paths (relative to repo root unless absolute) ---
EXPLAINX_DATA_ROOT=data
EXPLAINX_LOG_LEVEL=INFO
EXPLAINX_LOG_TO_FILE=true

# --- Database (optional; defaults to sqlite under EXPLAINX_DATA_ROOT/explainx.db) ---
# EXPLAINX_DATABASE_URL=sqlite:///C:/path/to/data/explainx.db

# --- Frontend (apps/web/.env.local) ---
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
