# =============================================================================
# ExplainX — Git ignore (runtime data, deps, secrets, build artifacts)
# =============================================================================

# --- Secrets & local env ---
.env
.env.local
.env.*.local
!.env.example

# --- Runtime data (never commit user projects / models / DB) ---
/data/**
!/data/.gitkeep
!/data/projects/.gitkeep
!/data/outputs/.gitkeep
!/data/models/.gitkeep
!/data/cache/.gitkeep
!/data/logs/.gitkeep
!/data/backups/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
backend/.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.sqlite3
*.db
*.db-wal
*.db-shm

# --- Node / Next.js ---
node_modules/
apps/web/node_modules/
apps/web/.next/
apps/web/out/
apps/web/build/
.npm
.pnpm-store/
*.tsbuildinfo
next-env.d.ts

# --- Logs & OS ---
*.log
logs/
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# --- Misc ---
*.mp4
*.wav
*.zip
.turbo/
coverage/
# AI models
backend/cache/
backend/cache/**
backend/models/
backend/models/**
!backend/models/.gitkeep
!backend/models/sd-turbo-openvino/
!backend/models/sd-turbo-openvino/.gitkeep
!backend/models/openvino_sd15/
!backend/models/openvino_sd15/.gitkeep
backend/generated/
backend/generated/**
!backend/generated/.gitkeep
!backend/generated/raw/
!backend/generated/raw/.gitkeep

# Smart asset library binaries (keep folder placeholders)
backend/asset_library/assets/**
!backend/asset_library/assets/.gitkeep
backend/asset_library/metadata/**
!backend/asset_library/metadata/.gitkeep
backend/asset_library/concepts/**
!backend/asset_library/concepts/.gitkeep
backend/asset_library/pending_review/**
!backend/asset_library/pending_review/.gitkeep
!backend/asset_library/README.md
data/models/
data/models/**

# Generated assets
outputs/
cache/
artifacts/

# ONNX models
*.onnx

# Optional
*.bin